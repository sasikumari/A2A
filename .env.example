# ── Model Configuration ──────────────────────────────────────────────────────
MODEL_PROVIDER=openai
MODEL_NAME=gpt-4o
OPENAI_API_KEY=sk-...

# ── Web Search ────────────────────────────────────────────────────────────────
TAVILY_API_KEY=tvly-...

# ── RAG Configuration ─────────────────────────────────────────────────────────
# "local"  → uses ChromaDB + BM25 from /documents folder
# "remote" → calls an external POST /rag/query endpoint
RAG_MODE=local
RAG_ENDPOINT=http://localhost:8000/rag/query

# Path to documents folder (relative to backend/)
DOCUMENTS_DIR=../documents

# ChromaDB persistence directory (relative to backend/)
CHROMA_PERSIST_DIR=./chroma_db
CHROMA_COLLECTION=upi_knowledge

# Embedding model (OpenAI)
EMBEDDING_MODEL=text-embedding-3-small

# Retrieval settings
BM25_TOP_K=10
DENSE_TOP_K=10
FINAL_TOP_K=6

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173
